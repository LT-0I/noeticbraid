{
  "$defs": {
    "PathPolicy": {
      "additionalProperties": false,
      "description": "Minimal write-kind policy for the vault layout.",
      "properties": {
        "allow_write_kinds": {
          "items": {
            "enum": [
              "generated_dashboard",
              "stable_record_create_only",
              "inbox_staging",
              "candidate_proposal",
              "sync_log_append_only"
            ],
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Allow Write Kinds",
          "type": "array"
        },
        "deny_write_kinds": {
          "items": {
            "enum": [
              "protected_user_raw",
              "plugin_or_config",
              "git_metadata",
              "outside_namespace",
              "path_traversal"
            ],
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Deny Write Kinds",
          "type": "array"
        }
      },
      "required": [
        "allow_write_kinds",
        "deny_write_kinds"
      ],
      "title": "PathPolicy",
      "type": "object"
    },
    "RootDir": {
      "additionalProperties": false,
      "description": "One top-level vault directory and its role.",
      "properties": {
        "path": {
          "pattern": "^[0-9]{2}_[a-z_]+/$",
          "title": "Path",
          "type": "string"
        },
        "role": {
          "enum": [
            "dashboard_workbench",
            "program_memory",
            "episodic_memory",
            "run_ledger_mirror",
            "templates",
            "bases",
            "inbox",
            "system_metadata"
          ],
          "title": "Role",
          "type": "string"
        }
      },
      "required": [
        "path",
        "role"
      ],
      "title": "RootDir",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Minimum vault layout object frozen into contract 1.2.0.",
  "properties": {
    "layout_id": {
      "maxLength": 128,
      "pattern": "^layout_[A-Za-z0-9_]+$",
      "title": "Layout Id",
      "type": "string"
    },
    "namespace_default": {
      "pattern": "^[A-Za-z][A-Za-z0-9_]*/$",
      "title": "Namespace Default",
      "type": "string"
    },
    "root_dirs": {
      "items": {
        "$ref": "#/$defs/RootDir"
      },
      "maxItems": 8,
      "minItems": 8,
      "title": "Root Dirs",
      "type": "array"
    },
    "path_policy": {
      "$ref": "#/$defs/PathPolicy"
    },
    "max_depth": {
      "maximum": 12,
      "minimum": 4,
      "title": "Max Depth",
      "type": "integer"
    },
    "traversal_check": {
      "const": "strict_no_parent",
      "title": "Traversal Check",
      "type": "string"
    },
    "test_cases_ref": {
      "anyOf": [
        {
          "const": "noeticbraid/docs/contracts/fixtures/path_policy_cases.json",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Test Cases Ref"
    }
  },
  "required": [
    "layout_id",
    "namespace_default",
    "root_dirs",
    "path_policy",
    "max_depth",
    "traversal_check"
  ],
  "title": "VaultLayoutMinimum",
  "type": "object"
}
