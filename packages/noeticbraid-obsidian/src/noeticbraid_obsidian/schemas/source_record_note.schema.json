{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://noeticbraid.local/schemas/contract-1.3.0/source_record_note.schema.json",
  "title": "NoeticBraid Obsidian hub source record note frontmatter",
  "description": "Contract 1.3.0 source record note frontmatter wrapper aligned to frozen SourceRecord 1.0.0 enums.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nb_type",
    "schema_version",
    "contract_version",
    "source_ref_id",
    "source_type",
    "title",
    "captured_at",
    "quality_score",
    "relevance_score",
    "tags"
  ],
  "properties": {
    "nb_type": {
      "type": "string",
      "const": "source_record",
      "description": "Vault note type marker."
    },
    "schema_version": {
      "type": "string",
      "const": "obsidian-hub-0.1",
      "description": "Obsidian hub schema family version."
    },
    "contract_version": {
      "type": "string",
      "const": "1.3.0",
      "description": "Contract freeze version for this vault note wrapper."
    },
    "source_ref_id": {
      "type": "string",
      "pattern": "^source_[A-Za-z0-9_]+$",
      "maxLength": 128,
      "description": "Stable source identifier prefixed with source_."
    },
    "source_type": {
      "type": "string",
      "enum": [
        "user_note",
        "web_page",
        "github_repo",
        "paper",
        "ai_output"
      ],
      "description": "Vault display subset of frozen SourceRecord.source_type; all values are from the frozen 8-value backend enum."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "description": "Source title. Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs."
    },
    "captured_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC-normalized capture timestamp."
    },
    "quality_score": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ],
      "description": "Frozen SourceRecord.quality_score value."
    },
    "relevance_score": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "unknown"
      ],
      "description": "Frozen SourceRecord.relevance_score value."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^noeticbraid/"
      },
      "minItems": 1,
      "maxItems": 16,
      "description": "Obsidian tags for NoeticBraid-generated or mirrored notes."
    },
    "canonical_url": {
      "description": "Optional canonical HTTP(S) URL. Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs. Must not include credential query parameters.",
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "maxLength": 2048,
          "format": "uri",
          "pattern": "^https?://",
          "not": {
            "pattern": "[?&](?:token|access_token|api[_-]?key|apikey|secret|password|passwd|cookie|session|auth|authorization)="
          }
        }
      ]
    },
    "local_path": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 1024,
      "description": "Optional local path for local-only or mirrored source material; blank string may normalize to null."
    },
    "source_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256,
      "description": "Optional vault-only internal reference. — vault-only 字段, 不写入 backend SourceRecord 1.0.0 API (与 SideNote.user_response.snoozed 一致风格)"
    },
    "external_url": {
      "description": "Optional external HTTP(S) URL. Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs. Must not include credential query parameters.",
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "string",
          "maxLength": 2048,
          "format": "uri",
          "pattern": "^https?://",
          "not": {
            "pattern": "[?&](?:token|access_token|api[_-]?key|apikey|secret|password|passwd|cookie|session|auth|authorization)="
          }
        }
      ]
    },
    "author": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256,
      "description": "Optional author, organization, or account label. Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs."
    },
    "retrieved_by_run_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^run_[A-Za-z0-9_]+$",
      "description": "Optional run identifier that retrieved or linked this source."
    },
    "content_hash": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^sha256:[0-9a-f]{64}$",
      "description": "sha256-prefixed content hash with lowercase hexadecimal digest."
    },
    "source_fingerprint": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256,
      "description": "Optional source fingerprint string for deduplication or provenance grouping."
    },
    "evidence_role": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "user_context",
            "reference_project",
            "source_grounding",
            "contradiction",
            "memory_update_evidence"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional frozen SourceRecord.evidence_role value."
    },
    "used_for_purpose": {
      "anyOf": [
        {
          "type": "string",
          "enum": [
            "project_positioning",
            "constraint_extraction",
            "source_grounding",
            "prior_art_check",
            "other"
          ]
        },
        {
          "type": "null"
        }
      ],
      "description": "Optional frozen SourceRecord.used_for_purpose value."
    }
  }
}
