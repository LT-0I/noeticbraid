{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "workflow_id",
    "status",
    "dry_run"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^run_[A-Za-z0-9_]+$"
    },
    "workflow_id": {
      "type": "string",
      "pattern": "^workflow_[A-Za-z0-9_]+$"
    },
    "status": {
      "enum": [
        "pending",
        "running",
        "blocked",
        "completed",
        "failed"
      ]
    },
    "dry_run": {
      "type": "boolean"
    }
  }
}
