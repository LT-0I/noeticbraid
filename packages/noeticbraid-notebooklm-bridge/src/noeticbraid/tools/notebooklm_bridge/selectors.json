{
  "version": "0.2.0",
  "notes": "Scoped selector candidates for NotebookLM. Keep semantic keys stable; update candidates after manual NotebookLM UI inspection.",
  "notebooklm": {
    "add_source_button": [
      "button[aria-label*='Add source' i]",
      "text=Add source",
      "button:has-text('Add source')"
    ],
    "source_url_tab": [
      "[role='tab'][aria-label*='Website' i]",
      "text=Website",
      "button:has-text('Website')"
    ],
    "source_text_tab": [
      "[role='tab'][aria-label*='Copied text' i]",
      "text=Copied text",
      "button:has-text('Copied text')"
    ],
    "source_url_input": [
      "input[type='url']",
      "textarea[aria-label*='URL' i]",
      "input[aria-label*='Website' i]"
    ],
    "source_title_input": [
      "input[aria-label*='Title' i]",
      "input[name='title']"
    ],
    "source_text_input": [
      "textarea[aria-label*='Paste text' i]",
      "textarea[aria-label*='Copied text' i]",
      "textarea"
    ],
    "source_submit_button": [
      "button[aria-label*='Insert' i]",
      "button[aria-label*='Add' i]",
      "text=Insert",
      "text=Add"
    ],
    "source_ready_indicator": [
      "[data-source-state='ready']",
      "[aria-label*='Sources' i]"
    ],
    "briefing_generate_button": [
      "button[aria-label*='Briefing' i]",
      "text=Briefing doc",
      "button:has-text('Briefing doc')"
    ],
    "briefing_refresh_button": [
      "button[aria-label*='Refresh briefing' i]",
      "text=Refresh"
    ],
    "briefing_content": [
      "[data-artifact-type='briefing']",
      "article:has-text('Briefing')",
      "[aria-label*='Briefing doc' i]"
    ],
    "faq_generate_button": [
      "button[aria-label*='FAQ' i]",
      "text=FAQ",
      "button:has-text('FAQ')"
    ],
    "faq_item": [
      "[data-artifact-type='faq'] [role='listitem']",
      "[aria-label*='FAQ' i] [role='listitem']",
      ".faq-item"
    ],
    "faq_question": [
      "[data-faq-question]",
      "h3",
      "strong"
    ],
    "faq_answer": [
      "[data-faq-answer]",
      "p",
      "div"
    ],
    "login_required_signal": [
      "a[href*='accounts.google.com']",
      "text=Sign in",
      "text=Verify it's you",
      "button:has-text('Sign in')"
    ]
  }
}
