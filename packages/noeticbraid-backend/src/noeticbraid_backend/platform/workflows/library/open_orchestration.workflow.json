{
  "workflow": {
    "id": "open_orchestration",
    "version": "1.0.0",
    "description": "Use when no curated workflow uniquely matches and the task should proceed through the generic local orchestration path.",
    "selector": {
      "intent_tags": [],
      "deliverable_types": [],
      "required_capabilities": [],
      "excluded_capabilities": [],
      "requirement_predicates": []
    },
    "inputs": [{"name": "request", "from": "requirement.text", "required": true}],
    "isolation": {"scope": "per_task", "persona_read": ["user_id/persona"], "persona_write": false},
    "nodes": [
      {"id": "elicit", "type": "interview", "impl": "clarifygpt_divergence"},
      {"id": "fanout", "type": "orchestrate", "agents": ["codex_cli", "gemini_cli", "claude_code"]},
      {"id": "critique_loop", "type": "reconcile", "max_rounds": 3, "exit": ["consensus", "good_enough", "marginal<0.05"]},
      {"id": "deliver", "type": "artifact_sink", "target": "task.deliverables"}
    ],
    "edges": [
      {"from": "elicit", "to": "fanout", "when": "requirement_confirmed"},
      {"from": "fanout", "to": "critique_loop"},
      {"from": "critique_loop", "to": "deliver", "when": "loop_terminated"}
    ],
    "termination": {"max_total_rounds": 3, "require_evidence_provenance": true},
    "capability_honesty": {"on_missing_capability": "declare_and_degrade"}
  }
}
