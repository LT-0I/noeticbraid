{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://noeticbraid.local/schemas/module-multimodel-alliance/convergence.schema.json",
  "title": "Convergence",
  "description": "Module-local draft record for final recommendation, objection handling, user decision points, next actions, and memory candidates.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "convergence_id",
    "task_id",
    "debate_id",
    "recommendation",
    "accepted_objections",
    "rejected_objections",
    "unresolved_disagreements",
    "user_decision_requirements",
    "next_actions",
    "memory_candidates",
    "decision_status"
  ],
  "properties": {
    "convergence_id": {
      "type": "string",
      "pattern": "^convergence_[A-Za-z0-9_]+$",
      "maxLength": 128
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_]+$",
      "maxLength": 128
    },
    "debate_id": {
      "type": "string",
      "pattern": "^debate_[A-Za-z0-9_]+$",
      "maxLength": 128
    },
    "recommendation": {
      "type": "string",
      "minLength": 1,
      "maxLength": 8192
    },
    "accepted_objections": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objection_id",
          "resolution",
          "evidence_refs"
        ],
        "properties": {
          "objection_id": {
            "type": "string",
            "pattern": "^obj_[A-Za-z0-9_]+$",
            "maxLength": 128
          },
          "resolution": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "evidence_refs": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string",
              "pattern": "^artifact_[A-Za-z0-9_]+$",
              "maxLength": 128
            }
          }
        }
      }
    },
    "rejected_objections": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objection_id",
          "rejection_reason",
          "evidence_refs"
        ],
        "properties": {
          "objection_id": {
            "type": "string",
            "pattern": "^obj_[A-Za-z0-9_]+$",
            "maxLength": 128
          },
          "rejection_reason": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "evidence_refs": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string",
              "pattern": "^artifact_[A-Za-z0-9_]+$",
              "maxLength": 128
            }
          }
        }
      }
    },
    "unresolved_disagreements": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objection_id",
          "severity",
          "summary",
          "carried_to",
          "evidence_refs"
        ],
        "properties": {
          "objection_id": {
            "type": "string",
            "pattern": "^obj_[A-Za-z0-9_]+$",
            "maxLength": 128
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "carried_to": {
            "type": "string",
            "enum": [
              "user_decision",
              "next_action",
              "more_evidence"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string",
              "pattern": "^artifact_[A-Za-z0-9_]+$",
              "maxLength": 128
            }
          }
        }
      }
    },
    "user_decision_requirements": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision_id",
          "question",
          "options",
          "blocking",
          "related_objection_refs"
        ],
        "properties": {
          "decision_id": {
            "type": "string",
            "pattern": "^decision_[A-Za-z0-9_]+$",
            "maxLength": 128
          },
          "question": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096
          },
          "options": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 2048
            }
          },
          "blocking": {
            "type": "boolean"
          },
          "related_objection_refs": {
            "type": "array",
            "maxItems": 32,
            "items": {
              "type": "string",
              "pattern": "^obj_[A-Za-z0-9_]+$",
              "maxLength": 128
            }
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "action_id",
          "owner",
          "action",
          "status"
        ],
        "properties": {
          "action_id": {
            "type": "string",
            "pattern": "^action_[A-Za-z0-9_]+$",
            "maxLength": 128
          },
          "owner": {
            "type": "string",
            "enum": [
              "orchestrator",
              "producer",
              "reviewer",
              "verifier",
              "user",
              "local_integrator"
            ]
          },
          "action": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          },
          "status": {
            "type": "string",
            "enum": [
              "planned",
              "blocked",
              "completed",
              "not_started"
            ]
          }
        }
      }
    },
    "memory_candidates": {
      "type": "array",
      "maxItems": 32,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "summary",
          "source_refs"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^memory_[A-Za-z0-9_]+$",
            "maxLength": 128
          },
          "summary": {
            "type": "string",
            "minLength": 1,
            "maxLength": 2048
          },
          "source_refs": {
            "type": "array",
            "maxItems": 16,
            "items": {
              "type": "string",
              "pattern": "^source_[A-Za-z0-9_]+$",
              "maxLength": 128
            }
          }
        }
      }
    },
    "decision_status": {
      "type": "string",
      "enum": [
        "accepted",
        "needs_user_decision",
        "needs_more_evidence",
        "rejected"
      ]
    }
  }
}
