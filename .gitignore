# Private state and secrets
state/
.env
.env.*
*.secret
*.key
*.pem
tokens.sqlite
*.dpapi*
*.encrypted

# Private subtree: keep placeholder READMEs (public-safe boundary docs),
# exclude actual private code/data that lands later
private/**
!private/README.md
!private/*/
!private/*/README.md

# Browser profile data is NEVER committed — credential/cookie stores.
# Whole-directory exclusion (a real Chrome user-data-dir scatters secrets
# across many paths: Cookies, Login Data, Network/, Local State, numbered
# Profile*/ dirs, etc.) — exclude everything, allow only a placeholder README.
**/browser-profiles/
**/browser-profile/
**/cdp-profile/
!**/browser-profiles/README.md
# HUB (web-ai-capability-hub) is referenced in place, not vendored.
# Any local pointer/mirror to its 11 GB credentialed data dir stays local-only.
/.hub-data
/.hub-data/
**/hub-profiles/
*.hub-data
# HUB MCP watchdog local state (issue/dedup bookkeeping — never committed)
/.hub-watchdog-state.json
.hub-watchdog-state.tmp

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.ruff_cache/

# Node
node_modules/
dist/
build/
.vite/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Generated package checksums
*.zip
*.zip.sha256

# Codex / OMX / pytest temp dirs (per-package or top-level)
.codex-tmp/
.omc/
.omx/
.tmp/
**/pytest-tmp/

# web-ai-capability-hub generated runtime state (browser profiles, sqlite DB, downloads, logs)
# Created when hub launches Chrome via CDP under NoeticBraid project root; never source.
data/

# Console test artifacts
packages/noeticbraid-console/playwright-report/
packages/noeticbraid-console/test-results/
packages/noeticbraid-console/.playwright-mcp/
