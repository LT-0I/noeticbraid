{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://noeticbraid.local/schemas/contract-1.3.0/task_note.schema.json",
  "title": "NoeticBraid Obsidian hub task note frontmatter",
  "description": "Contract 1.3.0 task note frontmatter wrapper aligned to frozen Task 1.0.0 enums. User request body text is not exposed as a frontmatter property in this schema. If a future contract exposes user_request, Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nb_type",
    "schema_version",
    "contract_version",
    "task_id",
    "task_type",
    "risk_level",
    "approval_level",
    "status",
    "source_channel",
    "created_at",
    "tags"
  ],
  "properties": {
    "nb_type": {
      "type": "string",
      "const": "task",
      "description": "Vault note type marker."
    },
    "schema_version": {
      "type": "string",
      "const": "obsidian-hub-0.1",
      "description": "Obsidian hub schema family version."
    },
    "contract_version": {
      "type": "string",
      "const": "1.3.0",
      "description": "Contract freeze version for this vault note wrapper."
    },
    "task_id": {
      "type": "string",
      "pattern": "^task_[A-Za-z0-9_]+$",
      "maxLength": 128,
      "description": "Stable task identifier prefixed with task_."
    },
    "task_type": {
      "type": "string",
      "enum": [
        "project_planning",
        "research",
        "code_review"
      ],
      "description": "Frozen Task.task_type enum subset exposed by the task note wrapper."
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "Frozen Task.risk_level value."
    },
    "approval_level": {
      "type": "string",
      "enum": [
        "none",
        "light",
        "strong",
        "forbidden"
      ],
      "description": "Frozen Task.approval_level value."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "ready",
        "queued",
        "running",
        "waiting_for_user",
        "failed",
        "completed"
      ],
      "description": "Frozen Task.status value."
    },
    "source_channel": {
      "type": "string",
      "enum": [
        "console",
        "obsidian",
        "im",
        "schedule",
        "local"
      ],
      "description": "Frozen Task.source_channel value."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC-normalized task creation timestamp."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^noeticbraid/"
      },
      "minItems": 1,
      "maxItems": 16,
      "description": "Obsidian tags for NoeticBraid-generated or mirrored notes."
    },
    "account_hint": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 64,
      "description": "Optional non-authoritative account routing hint. Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs."
    },
    "project_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 128,
      "description": "Optional project or workspace reference."
    }
  }
}
