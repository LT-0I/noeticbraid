{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://noeticbraid.local/schemas/contract-1.3.0/side_note.schema.json",
  "title": "NoeticBraid Obsidian hub side note frontmatter",
  "description": "Contract 1.3.0 side note frontmatter wrapper aligned to frozen SideNote 1.0.0 enums plus vault-only snoozed. Claim body text is not exposed as frontmatter in this schema. If a future contract exposes claim, Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nb_type",
    "schema_version",
    "contract_version",
    "note_id",
    "created_at",
    "linked_source_refs",
    "note_type",
    "confidence",
    "user_response",
    "tags"
  ],
  "properties": {
    "nb_type": {
      "type": "string",
      "const": "side_note",
      "description": "Vault note type marker."
    },
    "schema_version": {
      "type": "string",
      "const": "obsidian-hub-0.1",
      "description": "Obsidian hub schema family version."
    },
    "contract_version": {
      "type": "string",
      "const": "1.3.0",
      "description": "Contract freeze version for this vault note wrapper."
    },
    "note_id": {
      "type": "string",
      "pattern": "^note_[A-Za-z0-9_]+$",
      "maxLength": 128,
      "description": "Stable note identifier prefixed with note_."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "UTC-normalized note creation timestamp."
    },
    "linked_source_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^source_[A-Za-z0-9_]+$"
      },
      "minItems": 1,
      "maxItems": 64,
      "description": "Source references supporting or challenging the side note."
    },
    "note_type": {
      "type": "string",
      "enum": [
        "fact",
        "hypothesis",
        "challenge",
        "action"
      ],
      "description": "Frozen SideNote.note_type value."
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "Frozen SideNote.confidence value."
    },
    "user_response": {
      "type": "string",
      "enum": [
        "unread",
        "accepted",
        "rejected",
        "modified",
        "snoozed"
      ],
      "description": "Vault side-note handling state. unread, accepted, rejected, and modified are frozen SideNote 1.0.0 values. snoozed is a vault-only extension; it is not valid for the backend SideNote 1.0.0 API and must not be sent there."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^noeticbraid/"
      },
      "minItems": 1,
      "maxItems": 16,
      "description": "Obsidian tags for NoeticBraid-generated or mirrored notes."
    },
    "follow_up_ref": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^digestion_[A-Za-z0-9_]+$",
      "description": "Optional linked DigestionItem reference."
    },
    "project_ref": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 256,
      "description": "Optional project reference."
    }
  }
}
