{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://noeticbraid.local/schemas/contract-1.3.0/dashboard.schema.json",
  "title": "NoeticBraid Obsidian hub dashboard frontmatter",
  "description": "Contract 1.3.0 dashboard frontmatter schema for generated Obsidian hub dashboards.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nb_type",
    "schema_version",
    "contract_version",
    "dashboard_id",
    "title",
    "date",
    "generated",
    "generated_at",
    "tags"
  ],
  "properties": {
    "nb_type": {
      "type": "string",
      "const": "dashboard",
      "description": "Vault note type marker."
    },
    "schema_version": {
      "type": "string",
      "const": "obsidian-hub-0.1",
      "description": "Obsidian hub schema family version."
    },
    "contract_version": {
      "type": "string",
      "const": "1.3.0",
      "description": "Contract freeze version for this vault note wrapper."
    },
    "dashboard_id": {
      "type": "string",
      "pattern": "^dashboard_[A-Za-z0-9_]+$",
      "maxLength": 128,
      "description": "Stable dashboard identifier."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "Generated dashboard title. Must not contain secrets, tokens, cookies, API keys, or DPAPI blobs."
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Dashboard date in YYYY-MM-DD form."
    },
    "generated": {
      "type": "boolean",
      "const": true,
      "description": "Generated dashboards must declare generated=true."
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Generation timestamp in ISO 8601 date-time form."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^noeticbraid/"
      },
      "minItems": 1,
      "maxItems": 16,
      "description": "Obsidian tags for NoeticBraid-generated or mirrored notes."
    },
    "source_run_id": {
      "type": [
        "string",
        "null"
      ],
      "pattern": "^run_[A-Za-z0-9_]+$",
      "description": "Optional run identifier that generated or refreshed this dashboard."
    }
  }
}
